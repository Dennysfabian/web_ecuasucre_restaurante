---
const reviews = [
  {
    name:    'Rafael M.',
    initials:'RM',
    stars:   5,
    text:    '"Llevamos meses viniendo y nunca defrauda. La fritada con mote y el ceviche de camarón son espectaculares. El ambiente es íntimo y el servicio muy cercano."',
    date:    'Hace 2 semanas',
    color:   '#B85C26',
  },
  {
    name:    'Paola C.',
    initials:'PC',
    stars:   5,
    text:    '"El mejor encebollado que he probado fuera de Ecuador. Me hizo llorar de emoción. La dueña cocina con el alma. ¡Los viernes hacen fritada y hay que reservar sí o sí!"',
    date:    'Hace 1 mes',
    color:   '#C89632',
  },
  {
    name:    'David S.',
    initials:'DS',
    stars:   5,
    text:    '"Menú del día por 8€ es una locura en Barcelona. Qué buena comida, qué bien cocinada. El seco de pollo con arroz y los patacones... de otro nivel."',
    date:    'Hace 3 semanas',
    color:   '#5a7a3a',
  },
  {
    name:    'Ana L.',
    initials:'AL',
    stars:   5,
    text:    '"Un rincón de Ecuador en Barcelona. Para los que echamos de menos la comida de casa, este lugar es un tesoro. La guatita y los llapingachos son los mejores de la ciudad."',
    date:    'Hace 2 meses',
    color:   '#4a6a8a',
  },
];
---
<!-- ═══════════════════════════════════════════
     TESTIMONIOS — Reseñas reales de Google
═══════════════════════════════════════════ -->
<section id="testimonios" class="py-12 md:py-20" style="background:#110904;">
  <div class="sw">

    <!-- Encabezado -->
    <div class="text-center mb-8 md:mb-12 reveal">
      <p class="t-label mb-3">Lo Que Dicen Nuestros Clientes</p>
      <h2
        class="font-display font-semibold text-cream"
        style="font-size: clamp(1.8rem, 4vw, 2.9rem); line-height: 1.2;"
      >
        Palabras que<br/>
        <em class="text-gold not-italic">nos llenan el alma</em>
      </h2>
      <div class="gold-divider mx-auto mt-6"></div>

      <!-- Rating de Google -->
      <div class="flex items-center justify-center gap-2 mt-5">
        <div class="flex gap-[3px]">
          {[1,2,3,4,5].map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C89632">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <span class="font-brand text-[.6rem] tracking-[.15em] text-cream-soft/70 uppercase">4.8 · Google Reviews</span>
      </div>
    </div>

    <!-- Grid de testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {reviews.map((r, i) => (
        <div class={`testi-card reveal reveal-delay-${i + 1}`}>

          <!-- Comilla decorativa -->
          <span
            class="absolute top-3 right-5 font-display text-[5rem] leading-none select-none pointer-events-none"
            style="color: rgba(200,150,50,.07);"
          >"</span>

          <!-- Estrellas -->
          <div class="flex gap-[3px] mb-4">
            {Array.from({ length: r.stars }).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#C89632">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Texto del review -->
          <p class="font-display italic text-cream-soft text-[.88rem] leading-[1.85] mb-6 relative z-10">
            {r.text}
          </p>

          <!-- Autor -->
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
              style={`background: ${r.color}22; border: 1px solid ${r.color}44;`}
            >
              <span class="font-brand text-[.62rem] tracking-[.08em]" style={`color: ${r.color};`}>
                {r.initials}
              </span>
            </div>
            <div>
              <p class="font-brand text-[.62rem] tracking-[.15em] text-cream uppercase">{r.name}</p>
              <p class="text-cream-soft/50 text-[.72rem] mt-[2px]">⭐ Google Review · {r.date}</p>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Link a Google -->
    <div class="text-center mt-10 reveal reveal-delay-2">
      <a
        href="https://share.google/pXEdnz4mBvCMqyseH"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-[.65rem]"
        style="padding: .7rem 1.8rem;"
      >
        Ver todas las reseñas en Google
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </div>

  </div>
</section>
