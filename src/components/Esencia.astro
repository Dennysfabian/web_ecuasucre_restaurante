---
---
<!-- ═══════════════════════════════════════════
     NUESTRA ESENCIA — Storytelling asimétrico
═══════════════════════════════════════════ -->
<section id="esencia" class="py-12 md:py-20" style="background:#0D0806;">
  <div class="sw">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-20 items-center">

      <!-- ── TEXTO (izquierda) ── -->
      <div class="reveal-left">
        <p class="t-label mb-4">Nuestra Historia</p>

        <h2
          class="font-display font-semibold text-cream leading-[1.22] mb-5"
          style="font-size: clamp(1.9rem, 4vw, 3.1rem);"
        >
          Del corazón<br />del Ecuador<br />
          <em class="text-gold not-italic">a tu mesa</em>
        </h2>

        <div class="gold-divider mb-7"></div>

        <p class="text-cream-soft leading-[1.9] text-[.93rem] mb-4">
          Ecuasucre nació de una promesa sencilla: traer a cada plato el sabor
          genuino de las tres regiones del Ecuador. Desde los Andes hasta la
          Costa, cada receta lleva el peso de una tradición que se transmite
          de generación en generación.
        </p>
        <p class="text-cream-soft leading-[1.9] text-[.93rem] mb-8">
          Cocinamos con ingredientes frescos, técnicas de siempre y el cariño
          que solo una cocina familiar puede dar. Aquí, cada bocado es un
          viaje a casa.
        </p>

        <a href="#regiones" class="btn-outline">Conoce las Regiones</a>
      </div>

      <!-- ── IMAGEN con marco dorado (derecha) ── -->
      <div class="reveal-right relative">

        <!-- NOTA DEV: Interior del local — foto interior_dos.webp, ambiente cálido -->
        <div class="relative overflow-hidden rounded-[4px]" style="box-shadow: 0 32px 64px rgba(0,0,0,.55);">
          <img
            src="/imagenes/interior_dos.webp"
            alt="Interior Ecuasucre — ambiente acogedor"
            class="w-full h-[440px] object-cover"
            style="filter: brightness(.9) saturate(1.12);"
            loading="lazy"
          />
          <!-- Capa de color cálido sutil -->
          <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(184,92,38,.06) 0%, transparent 60%);"></div>
        </div>

        <!-- Marco de borde dorado desplazado -->
        <div
          class="absolute pointer-events-none rounded-[4px]"
          style="inset: -10px; border: 1px solid rgba(200,150,50,.2); z-index:-1;"
        ></div>

        <!-- Badge flotante en la esquina inferior -->
        <div
          class="absolute bottom-[-1.2rem] left-1/2 -translate-x-1/2 whitespace-nowrap px-5 py-2 rounded-[2px]"
          style="background:#0D0806; border:1px solid rgba(200,150,50,.2);"
        >
          <span class="font-brand text-[.53rem] tracking-[.22em] text-gold uppercase">
            Sabor Auténtico · Corazón Ecuatoriano
          </span>
        </div>
      </div>

    </div>
  </div>
</section>
