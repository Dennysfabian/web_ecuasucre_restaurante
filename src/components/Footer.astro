---
---
<!-- ═══════════════════════════════════════════
     FOOTER
═══════════════════════════════════════════ -->
<footer style="background:#070403; border-top:1px solid rgba(200,150,50,.1); padding:4rem 0 2.5rem;">
  <div class="sw">

    <div class="flex flex-col items-center gap-5 mb-8">

      <!-- Logo footer -->
      <!-- NOTA DEV: Logo Ecuasucre — filtro dorado suave -->
      <img
        src="/imagenes/logo_sucre.png"
        alt="Ecuasucre"
        class="h-[62px] w-auto object-contain"
        style="filter: drop-shadow(0 0 12px rgba(200,150,50,.22));"
      />

      <p class="t-label text-[.56rem]">Cocina Ecuatoriana Auténtica · Barcelona</p>

      <!-- Nav links footer -->
      <nav class="flex flex-wrap justify-center gap-x-8 gap-y-3">
        {[
          { href: '#esencia',         label: 'Historia'   },
          { href: '#regiones',        label: 'Regiones'   },
          { href: '#especialidades',  label: 'Carta'      },
          { href: '#galeria',         label: 'Galería'    },
          { href: '#testimonios',     label: 'Reseñas'    },
          { href: '#contacto',        label: 'Reservas'   },
        ].map((link) => (
          <a
            href={link.href}
            class="font-brand text-[.56rem] tracking-[.2em] text-cream-soft/60 no-underline uppercase hover:text-gold transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Separador -->
      <div class="w-14 h-[1px]" style="background: linear-gradient(90deg, transparent, rgba(200,150,50,.28), transparent);"></div>

      <!-- Redes sociales -->
      <div class="flex items-center gap-5">
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/acuasucre"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook Ecuasucre"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="border:1px solid rgba(200,150,50,.2); color:rgba(200,150,50,.5);"
          onmouseover="this.style.borderColor='rgba(200,150,50,.55)';this.style.color='#C89632';"
          onmouseout="this.style.borderColor='rgba(200,150,50,.2)';this.style.color='rgba(200,150,50,.5)';"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/ecuasucre"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram Ecuasucre"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="border:1px solid rgba(200,150,50,.2); color:rgba(200,150,50,.5);"
          onmouseover="this.style.borderColor='rgba(200,150,50,.55)';this.style.color='#C89632';"
          onmouseout="this.style.borderColor='rgba(200,150,50,.2)';this.style.color='rgba(200,150,50,.5)';"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/34933254392"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp Ecuasucre"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="border:1px solid rgba(200,150,50,.2); color:rgba(200,150,50,.5);"
          onmouseover="this.style.borderColor='rgba(200,150,50,.55)';this.style.color='#C89632';"
          onmouseout="this.style.borderColor='rgba(200,150,50,.2)';this.style.color='rgba(200,150,50,.5)';"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- Copyright -->
    <p class="font-brand text-center text-[.52rem] tracking-[.2em] uppercase" style="color:rgba(200,150,50,.2);">
      © 2025 Ecuasucre · Todos los derechos reservados · Cocina Ecuatoriana en Barcelona
    </p>

    <!-- Powered by -->
    <p class="text-center mt-3" style="font-family:'Lato',sans-serif; font-size:.6rem; color:rgba(196,174,138,.22); letter-spacing:.08em;">
      Powered by&nbsp;
      <a
        href="https://www.tanesolutions.com"
        target="_blank"
        rel="noopener noreferrer"
        style="color:rgba(196,174,138,.38); text-decoration:none; letter-spacing:.12em; font-family:'Cinzel',serif; font-size:.55rem; text-transform:uppercase; transition:color .25s;"
        onmouseover="this.style.color='rgba(200,150,50,.65)'"
        onmouseout="this.style.color='rgba(196,174,138,.38)'"
      >Tane Solutions</a>
    </p>

  </div>
</footer>
