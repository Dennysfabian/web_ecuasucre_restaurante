---
const platos = [
  {
    slot:    'featured',
    img:     '/imagenes/plato_ceviche.webp',
    imgAlt:  'Ceviche Mixto — camarones y calamar',
    region:  'La Costa',
    name:    'Ceviche Mixto',
    desc:    'Camarones y calamar marinados en limón y naranjilla, con chifles crujientes y tostado. El Pacífico en cada cucharada.',
    price:   '12,50 €',
    badge:   'Estrella',
    featured: true,
  },
  {
    slot:   'b',
    img:    '/imagenes/plato_fritada.webp',
    imgAlt: 'Fritada Serrana',
    region: 'La Sierra',
    name:   'Fritada Serrana',
    desc:   'Cerdo frito a fuego lento, con mote, choclo, maduro y salsa criolla.',
    price:  '13,00 €',
    badge:  'Chef',
  },
  {
    slot:   'c',
    img:    '/imagenes/plato_guatita.webp',
    imgAlt: 'Guatita — mondongo en salsa de maní',
    region: 'La Sierra',
    name:   'Guatita',
    desc:   'Mondongo en salsa de maní con papa y ají. Una receta que se hereda, no se inventa.',
    price:  '11,50 €',
    badge:  'Clásico',
  },
  {
    slot:   'd',
    img:    '/imagenes/plato_menestra.webp',
    imgAlt: 'Menestra con Carne',
    region: 'La Sierra',
    name:   'Menestra con Carne',
    desc:   'Lentejas guisadas con carne asada, arroz y maduro. El plato del día a día ecuatoriano.',
    price:  '10,50 €',
    badge:  'Popular',
  },
];
---
<!-- ═══════════════════════════════════════════
     ESPECIALIDADES — Diseño Bento UI asimétrico
═══════════════════════════════════════════ -->
<section id="especialidades" class="py-12 md:py-20" style="background:#0D0806;">
  <div class="sw">

    <!-- Encabezado -->
    <div class="text-center mb-8 md:mb-12 reveal">
      <p class="t-label mb-3">Nuestros Platos</p>
      <h2
        class="font-display font-semibold text-cream"
        style="font-size: clamp(1.8rem, 4vw, 2.9rem); line-height: 1.2;"
      >
        Especialidades<br/>
        <em class="text-gold not-italic">de la casa</em>
      </h2>
      <div class="gold-divider mx-auto mt-6"></div>
    </div>

    <!-- ── BENTO GRID ── -->
    <div class="bento-services reveal">

      <!-- ── CARD FEATURED (Ceviche — ocupa col 1, filas 1+2) ── -->
      <!-- NOTA DEV: plato_ceviche.webp — imagen principal del bento, card grande -->
      <div class="bento-featured plato-card group">
        <div class="card-img-wrap w-full" style="height:100%; min-height:380px;">
          <img src={platos[0].img} alt={platos[0].imgAlt} loading="lazy" style="height:100%;"/>
        </div>
        <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(13,8,6,.94) 0%, rgba(13,8,6,.15) 55%, transparent 100%);"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <span class="t-label">{platos[0].region}</span>
          <h3 class="font-display text-[1.55rem] text-cream mt-2 mb-2 font-semibold leading-tight">
            {platos[0].name}
          </h3>
          <p class="text-[.8rem] text-cream-soft/85 leading-[1.7] mb-4">{platos[0].desc}</p>
          <div class="flex items-center justify-between">
            <span class="font-brand text-[1.1rem] text-gold">{platos[0].price}</span>
            <span class="font-brand text-[.52rem] tracking-[.14em] text-gold border border-gold/30 px-3 py-1 rounded-sm">
              {platos[0].badge} ✦
            </span>
          </div>
        </div>
      </div>

      <!-- ── CARDS regulares ── -->
      {platos.slice(1).map((p, i) => {
        const slotClass = `bento-${p.slot}`;
        return (
          <div class={`${slotClass} plato-card group reveal reveal-delay-${i + 1}`}>
            <!-- NOTA DEV: {p.imgAlt} — usar {p.img} -->
            <div class="card-img-wrap w-full relative" style="height:58%;">
              <img src={p.img} alt={p.imgAlt} loading="lazy" style="width:100%;height:100%;"/>
            </div>
            <div class="p-4 flex-1">
              <span class="t-label text-[.5rem]">{p.region}</span>
              <h3 class="font-display text-[1rem] text-cream mt-1 mb-1 font-semibold leading-tight">
                {p.name}
              </h3>
              <p class="text-[.75rem] text-cream-soft leading-[1.65] mb-3">{p.desc}</p>
              <div class="flex items-center justify-between pt-2" style="border-top:1px solid rgba(200,150,50,.1);">
                <span class="font-brand text-[.9rem] text-gold">{p.price}</span>
                <span class="font-brand text-[.5rem] text-cream-soft/60 tracking-[.1em]">{p.badge} ✦</span>
              </div>
            </div>
          </div>
        );
      })}

      <!-- ── MENÚ DEL DÍA — card promo (col 3, fila 2) ── -->
      <div
        class="bento-menu reveal reveal-delay-4 flex flex-col items-center justify-center text-center p-5 rounded-[6px] relative overflow-hidden"
        style="background: linear-gradient(135deg, #1C0F07 0%, #231408 100%); border: 1px solid rgba(200,150,50,.22);"
      >
        <!-- Fondo decorativo sutil -->
        <div class="absolute inset-0 opacity-[.04]" style="background-image: repeating-linear-gradient(45deg, #C89632 0, #C89632 1px, transparent 0, transparent 50%); background-size: 12px 12px;"></div>

        <p class="t-label mb-2 relative z-10">Menú del Día</p>
        <div
          class="font-display font-bold text-gold relative z-10"
          style="font-size: clamp(2rem, 4vw, 2.8rem); line-height: 1; text-shadow: 0 0 30px rgba(200,150,50,.3);"
        >
          8 <span class="text-[1.2rem]">€</span>
        </div>
        <p class="font-brand text-[.52rem] tracking-[.18em] text-cream-soft/60 mt-1 relative z-10">LUNES A VIERNES</p>
        <div class="w-10 h-[1px] mx-auto my-3 relative z-10" style="background: rgba(200,150,50,.3);"></div>
        <p class="text-[.75rem] text-cream-soft/80 leading-[1.65] relative z-10">
          Primer plato + segundo + postre o bebida
        </p>
      </div>

    </div>

    <!-- CTA inferior -->
    <div class="text-center mt-12 reveal reveal-delay-1">
      <p class="font-display italic text-cream-soft text-[.9rem] mb-5">
        Carta completa disponible en el restaurante y al reservar tu mesa.
      </p>
      <a href="#contacto" class="btn-primary">Reservar Mesa</a>
    </div>

  </div>
</section>

<!-- ── GALERÍA integrada (Bento de interiores) ── -->
<section id="galeria" class="pb-12 md:pb-20" style="background:#0D0806;">
  <div class="sw">

    <div class="text-center mb-7 md:mb-10 reveal">
      <p class="t-label mb-3">El Ambiente</p>
      <h2
        class="font-display font-semibold text-cream"
        style="font-size: clamp(1.7rem, 3.5vw, 2.6rem); line-height: 1.2;"
      >
        Un espacio para<br/>
        <em class="text-gold not-italic">compartir</em>
      </h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <!-- Grid bento de interiores -->
    <div class="grid gap-3 reveal" style="grid-template-columns: 1.5fr 1fr; grid-template-rows: 260px 260px;">
      <!-- NOTA DEV: interior_uno.webp — foto más amplia del local, card grande izquierda -->
      <div class="card-img-wrap rounded-[6px] overflow-hidden" style="grid-row: 1 / 3;">
        <img src="/imagenes/interior_uno.webp" alt="Interior Ecuasucre" class="w-full h-full object-cover" loading="lazy" style="height:532px;"/>
      </div>
      <!-- NOTA DEV: interior_tres.webp — detalle de mesa o rincón, card derecha superior -->
      <div class="card-img-wrap rounded-[6px] overflow-hidden">
        <img src="/imagenes/interior_tres.webp" alt="Sala Ecuasucre" class="w-full h-full object-cover" loading="lazy"/>
      </div>
      <!-- NOTA DEV: interior_cuatro.webp — otro ángulo del local, card derecha inferior -->
      <div class="card-img-wrap rounded-[6px] overflow-hidden">
        <img src="/imagenes/interior_cuatro.webp" alt="Rincón Ecuasucre" class="w-full h-full object-cover" loading="lazy"/>
      </div>
    </div>

  </div>
</section>
