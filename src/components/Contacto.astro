---
const horarios = [
  { dias: 'Martes — Miércoles', horas: '12:00 — 22:00', highlight: false },
  { dias: 'Jueves — Viernes',   horas: '12:00 — 23:30', highlight: false },
  { dias: 'Sábado',             horas: '11:00 — 23:30', highlight: true  },
  { dias: 'Domingo',            horas: '11:00 — 22:00', highlight: true  },
  { dias: 'Lunes',              horas: 'Cerrado',        highlight: false, closed: true },
];
---
<!-- ═══════════════════════════════════════════
     CONTACTO — Horarios + Reservas
═══════════════════════════════════════════ -->
<section id="contacto" class="py-12 md:py-20 relative overflow-hidden" style="background:#0D0806;">

  <!-- Decoración Andina (esquinas) -->
  <svg class="andean-deco" style="top:0;right:0;width:280px;height:280px;opacity:.04;transform:rotate(90deg);" viewBox="0 0 200 200" fill="none">
    <path d="M0,0 L90,0 L90,18 L18,18 L18,90 L0,90 Z" fill="#C89632"/>
    <path d="M0,0 L60,0 L60,12 L12,12 L12,60 L0,60 Z" fill="#C89632" opacity=".5"/>
    <path d="M0,0 L32,0 L32,6  L6,6   L6,32  L0,32 Z" fill="#C89632" opacity=".3"/>
  </svg>
  <svg class="andean-deco" style="bottom:0;left:0;width:260px;height:260px;opacity:.04;transform:rotate(270deg);" viewBox="0 0 200 200" fill="none">
    <path d="M0,0 L90,0 L90,18 L18,18 L18,90 L0,90 Z" fill="#C89632"/>
    <path d="M0,0 L60,0 L60,12 L12,12 L12,60 L0,60 Z" fill="#C89632" opacity=".45"/>
  </svg>

  <div class="sw relative z-10">

    <!-- Encabezado -->
    <div class="text-center mb-8 md:mb-12 reveal">
      <p class="t-label mb-3">Visítanos</p>
      <h2
        class="font-display font-semibold text-cream"
        style="font-size: clamp(1.8rem, 4vw, 2.9rem); line-height: 1.2;"
      >
        Horarios &amp;<br/>
        <em class="text-gold not-italic">Reservas</em>
      </h2>
      <div class="gold-divider mx-auto mt-6"></div>
    </div>

    <!-- 2 columnas: Horarios + Reserva -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-20 items-start">

      <!-- ── HORARIOS (izquierda) ── -->
      <div class="reveal-left">
        <h3 class="font-brand text-[.68rem] tracking-[.25em] text-gold uppercase mb-6">
          Horario de Apertura
        </h3>

        <div class="space-y-0">
          {horarios.map((h) => (
            <div class="horario-row">
              <span
                class="font-display text-[.92rem] leading-snug"
                style={h.closed ? 'color:rgba(240,228,204,.3);' : 'color:#F0E4CC;'}
              >
                {h.dias}
              </span>
              <span
                class="font-brand text-[.75rem] tracking-[.08em]"
                style={h.closed ? 'color:rgba(200,150,50,.28);' : h.highlight ? 'color:#C89632;' : 'color:#C4AE8A;'}
              >
                {h.horas}
              </span>
            </div>
          ))}
        </div>

        <!-- Dirección -->
        <div
          class="mt-7 p-5 rounded-[4px]"
          style="background:#1C0F07; border:1px solid rgba(200,150,50,.1);"
        >
          <p class="t-label text-[.54rem] mb-2">Ubicación</p>
          <p class="font-display text-[.96rem] text-cream mb-1">
            📍 Calle Floridablanca, 37
          </p>
          <p class="text-cream-soft text-[.82rem]">esquina Rocafort · 08015 Barcelona</p>
          <a
            href="https://maps.google.com/?q=Calle+Floridablanca+37+Barcelona"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-3 text-gold/70 text-[.72rem] font-brand tracking-[.1em] uppercase hover:text-gold transition-colors duration-200"
          >
            Abrir en Google Maps
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- ── RESERVAS (derecha) ── -->
      <div class="reveal-right">
        <h3 class="font-brand text-[.68rem] tracking-[.25em] text-gold uppercase mb-6">
          Haz Tu Reserva
        </h3>

        <p class="text-cream-soft leading-[1.9] text-[.9rem] mb-7">
          Reserva tu mesa y asegúrate de vivir la experiencia Ecuasucre. Para grupos
          de más de 6 personas, te pedimos que contactes directamente por WhatsApp
          o teléfono para organizar el mejor servicio para ti.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col gap-3">

          <!-- WhatsApp (con pulse) -->
          <a
            href="https://wa.me/34933254392?text=Hola!%20Quiero%20reservar%20una%20mesa%20en%20Ecuasucre."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Reservar por WhatsApp
          </a>

          <!-- Teléfono -->
          <a href="tel:+34933254392" class="btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Llamar: 933 254 392
          </a>

        </div>

        <!-- Cita editorial -->
        <div
          class="mt-7 p-5 rounded-[4px] text-center"
          style="background:#1C0F07; border:1px solid rgba(200,150,50,.08);"
        >
          <p class="font-display italic text-cream-soft text-[.86rem] leading-[1.78]">
            "La cocina ecuatoriana es una de las más ricas de América Latina
            — y nosotros la traemos a tu mesa."
          </p>
          <div class="w-8 h-[1px] mx-auto mt-3" style="background:rgba(200,150,50,.3);"></div>
        </div>

      </div>

    </div>
  </div>
</section>
